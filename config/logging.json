{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "file_formatter": {
      "format": "%(levelname)s - %(module)s:L%(lineno)d - %(asctime)s - %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    },
    "console_formatter": {
      "()": "project.logging.JsonFormatter",
      "format": "%(asctime)s [%(levelname)s] %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "handlers": {
    "file_handler": {
      "class": "logging.handlers.RotatingFileHandler",
      "filename": "logs/flame-storage-debug.log",
      "encoding": "utf-8",
      "mode": "a",
      "maxBytes": 4194304,
      "backupCount": 5,
      "formatter": "file_formatter",
      "level": "DEBUG"
    },
    "console_handler": {
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout",
      "formatter": "console_formatter",
      "level": "INFO"
    }
  },
  "root": {
    "level": "INFO",
    "handlers": ["file_handler", "console_handler"]
  },
  "loggers": {
    "fastapi": {
      "level": "INFO",
      "propagate": true
    },
    "uvicorn": {
      "level": "INFO",
      "propagate": true
    },
    "uvicorn.error": {
      "level": "INFO",
      "propagate": true
    },
    "uvicorn.access": {
      "level": "INFO",
      "propagate": true
    },
    "httpx": {
      "level": "WARNING"
    }
  }
}
